<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .login-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .login-body {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 24px;
        }
        .login-box {
            width: 100%;
            max-width: 400px;
        }
        .login-header {
            text-align: center;
            margin-bottom: 40px;
        }
        .login-logo {
            width: 56px; height: 56px;
            background: var(--accent-green);
            clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--mono);
            font-size: 20px;
            font-weight: bold;
            color: var(--bg-primary);
            margin: 0 auto 16px;
        }
        .login-title {
            font-family: var(--cond);
            font-size: 22px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-primary);
        }
        .login-sub {
            font-family: var(--mono);
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 4px;
        }
        .login-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
        }
        .login-card-header {
            background: var(--bg-elevated);
            border-bottom: 1px solid var(--border);
            padding: 10px 20px;
            font-family: var(--mono);
            font-size: 11px;
            color: var(--text-dim);
            letter-spacing: 0.1em;
        }
        .login-card-body {
            padding: 28px 24px;
        }
        .login-footer-note {
            text-align: center;
            font-family: var(--mono);
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 20px;
            line-height: 1.8;
        }
    </style>
</head>
<body>
<div class="login-wrapper">

    <div class="system-bar">
        <div>
            <span class="status-dot"></span>
            <span>SISTEMA OPERATIVO</span>
            &nbsp;|&nbsp;
            <span>LegacyReportEngine/2.1.3</span>
        </div>
        <div class="system-bar-right">
            <span id="sys-clock" class="text-mono">00:00:00</span>
        </div>
    </div>

    <div class="login-body">
        <div class="login-box">

            <div class="login-header">
                <div class="login-logo">LR</div>
                <div class="login-title">LegacyReport Engine</div>
                <div class="login-sub">// Autenticazione richiesta per l'accesso</div>
            </div>

            <% if (error) { %>
            <div class="alert alert-error">
                <span class="alert-prefix">[ERR]</span>
                <span><%= error %></span>
            </div>
            <% } %>

            <div class="login-card">
                <div class="login-card-header">
                    POST /api/auth/login
                </div>
                <div class="login-card-body">
                    <form method="POST" action="/api/auth/login">
                        <div class="form-group">
                            <label class="form-label">
                                Username <span class="required">*</span>
                            </label>
                            <input
                                type="text"
                                name="username"
                                class="form-control"
                                placeholder="username"
                                autocomplete="off"
                                required
                            >
                        </div>
                        <div class="form-group">
                            <label class="form-label">
                                Password <span class="required">*</span>
                            </label>
                            <input
                                type="password"
                                name="password"
                                class="form-control"
                                placeholder="••••••••"
                                required
                            >
                        </div>
                        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center">
                            Autenticati →
                        </button>
                    </form>
                </div>
            </div>

            <div class="login-footer-note">
                Accesso riservato al personale autorizzato.<br>
                Tutti gli accessi sono registrati e monitorati.<br>
                <span style="color: var(--accent-amber)">Legacy Corp. — Sistema Interno</span>
            </div>

        </div>
    </div>

    <footer class="main-footer">
        <span>LegacyReportEngine v2.1.3</span>
        <span>Apache/2.2.31 (Ubuntu)</span>
    </footer>

</div>
<script src="/js/dashboard.js"></script>
</body>
</html>
